pipeline {
  agent {
    docker {
      image 'maven:3.9.9-eclipse-temurin-17'
      args '-u root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  environment {
    DOCKER_IMAGE = "manavdhruve15/ultimate-cicd:${BUILD_NUMBER}"
    GITHUB_REPO = "https://github.com/Manav015/Jenkins-Zero-To-Hero.git"
    SONAR_URL = "http://18.221.210.34:9000/"
  }

  stages {

    stage('Install Tools') {
      steps {
        sh '''
          apt-get update
          apt-get install -y docker.io git
          docker --version
          git --version
        '''
      }
    }

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Workspace Check') {
      steps {
        sh '''
          pwd
          ls -la
        '''
      }
    }

    stage('Build Maven App') {
      steps {
        dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
          sh 'mvn clean package'
        }
      }
    }

    stage('SonarQube Analysis') {
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
            sh """
              mvn sonar:sonar \
              -Dsonar.login=$SONAR_AUTH_TOKEN \
              -Dsonar.host.url=$SONAR_URL
            """
          }
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        sh '''
          cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
          docker build -t $DOCKER_IMAGE .
        '''
      }
    }

    stage('Push Docker Image') {
      steps {
        script {
          def image = docker.image("${DOCKER_IMAGE}")

          docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
            image.push()
          }
        }
      }
    }

    stage('Update Deployment File') {
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
            # Fix Git safe directory issue
            git config --global --add safe.directory /var/lib/jenkins/workspace/ultimate-cicd

            git config --global user.email "manavdhruve15@gmail.com"
            git config --global user.name "Manav Dhruve"

            # Update image tag
            sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml

            git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml

            git commit -m "Updated image tag ${BUILD_NUMBER}" || echo "No changes"

            git push https://${GITHUB_TOKEN}@github.com/Manav015/Jenkins-Zero-To-Hero.git HEAD:main
          '''
        }
      }
    }
  }

  post {
    always {
      echo "Pipeline execution completed"
    }
  }
}
